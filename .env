# Database Config
POSTGRES_USER=uraas_user
POSTGRES_PASSWORD=uraas_pass
POSTGRES_DB=uraas_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=sqlite:///uraas.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
STORAGE_PATH=./storage
STORAGE_MIN_FREE_GB=10.0

# Crawler Config
RATE_LIMIT_DELAY=2.0
MAX_DEPTH=10
CONCURRENT_REQUESTS=16

# Dashboard
DASHBOARD_PORT=8080
DASHBOARD_SECRET_KEY=super-secret-key-change-me
